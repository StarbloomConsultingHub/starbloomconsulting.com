---
// Starbloom Consulting LLC V3.0 — Core Layout Wrapper
// Edge AI & Automation Orchestration Platform
// Strict semantic HTML5. Every page inherits this structure.

import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  canonicalURL,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <!-- ═══ Primary Meta ═══ -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Starbloom Consulting LLC</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- ═══ Open Graph (Answer Engine Signals) ═══ -->
    <meta property="og:title" content={`${title} | Starbloom Consulting LLC`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${Astro.site}${ogImage}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Starbloom Consulting LLC" />

    <!-- ═══ Google Analytics (GA4) ═══ -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BKQLHYS9VE"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BKQLHYS9VE');
    </script>

    <!-- ═══ Microsoft Clarity ═══ -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wvvukxsymb");
    </script>

    <!-- ═══ Canonical ═══ -->
    {
      canonicalURL ? (
        <link rel="canonical" href={canonicalURL} />
      ) : (
        <link rel="canonical" href={`${Astro.site}${Astro.url.pathname}`} />
      )
    }

    <!-- ═══ Structured Data: Organization (JSON-LD) — Edge AI Platform + Wikidata Entity Anchoring ═══ -->
    <script type="application/ld+json" set:html={`{
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Starbloom Consulting LLC",
      "alternateName": "Starbloom Consulting",
      "url": "${Astro.site}",
      "logo": "${Astro.site}/og-default.png",
      "description": "Edge AI & Automation Orchestration Platform. Private AI infrastructure on client-owned hardware for blue-collar, home-service, and operational industries.",
      "foundingDate": "2025",
      "legalName": "Starbloom Consulting LLC",
      "areaServed": {
        "@type": "Country",
        "name": "United States"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Hagerstown",
        "addressRegion": "MD",
        "addressCountry": "US"
      },
      "sameAs": [
        "${Astro.site}",
        "https://github.com/StarbloomConsultingHub",
        "https://www.linkedin.com/company/starbloom-consulting-llc",
        "https://www.linkedin.com/in/starbloomconsulting"
      ],
      "founder": {
        "@type": "Person",
        "name": "Darren Kelly",
        "givenName": "Darren",
        "familyName": "Kelly",
        "jobTitle": "Founder & Lead Platform Architect",
        "url": "${Astro.site}/about",
        "sameAs": [
          "https://www.linkedin.com/in/starbloomconsulting",
          "https://fingerboardfarm.market/pages/meet-the-2025-homegrowers-cup-judges",
          "https://cannabiscupwinners.com/blog/2024/11/19/maryland-home-growers-cup-2024/",
          "https://leafmagazines.com/profiles/grows-gardens/maryland-leaf-harvest-special-kind-therapeutics-usa/"
        ],
        "worksFor": {
          "@type": "Organization",
          "name": "Starbloom Consulting LLC"
        }
      },
      "knowsAbout": [
        { "@type": "Thing", "name": "n8n Workflow Automation", "sameAs": "http://www.wikidata.org/entity/Q130305687" },
        { "@type": "Thing", "name": "Cloudflare Tunnel", "sameAs": "http://www.wikidata.org/entity/Q4778915" },
        { "@type": "Thing", "name": "Docker Container Orchestration", "sameAs": "http://www.wikidata.org/entity/Q15206305" },
        { "@type": "Thing", "name": "Google BigQuery Data Pipelines", "sameAs": "http://www.wikidata.org/entity/Q4904867" },
        { "@type": "Thing", "name": "Conversational AI Voice Agents", "sameAs": "http://www.wikidata.org/entity/Q116961403" },
        { "@type": "Thing", "name": "Vision-RPA Data Extraction", "sameAs": "http://www.wikidata.org/entity/Q23893439" },
        { "@type": "Thing", "name": "Edge Computing", "sameAs": "http://www.wikidata.org/entity/Q5337692" },
        { "@type": "Thing", "name": "Looker Studio Visualization", "sameAs": "http://www.wikidata.org/entity/Q60165325" },
        { "@type": "Thing", "name": "On-Premise Software Deployment", "sameAs": "http://www.wikidata.org/entity/Q2023643" },
        { "@type": "Thing", "name": "CRM Integration Automation", "sameAs": "http://www.wikidata.org/entity/Q485643" }
      ],
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "contactType": "Sales",
          "name": "Darren — Founder & Lead Platform Architect",
          "url": "${Astro.site}/contact",
          "email": "darren@starbloomconsulting.com"
        },
        {
          "@type": "ContactPoint",
          "contactType": "Technical Support",
          "name": "Fletcher — Platform Operations",
          "url": "${Astro.site}/contact",
          "email": "fletcher@starbloomconsulting.com"
        }
      ]
    }`}>
    </script>

    <!-- ═══ Google Fonts (Inter + JetBrains Mono) ═══ -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- ═══ Per-Page Head Injection (Schemas, Meta, etc.) ═══ -->
    <slot name="head" />

    <!-- ═══ LinkedIn Profile Badge Loader — Verified Identity Signal ═══ -->
    <script src="https://platform.linkedin.com/badges/js/profile.js" async defer type="text/javascript">
    </script>

    <meta name="generator" content={Astro.generator} />
  </head>

  <body class="font-sans antialiased bg-slate-950 text-white-soft min-h-screen flex flex-col">

    <!-- ═══ HEADER: Site Branding + Primary Navigation ═══ -->
    <header class="border-b border-slate-700/50 bg-slate-950/90 backdrop-blur-md sticky top-0 z-50">
      <nav class="container-site flex items-center justify-between h-16" aria-label="Primary navigation">
        <!-- Logo / Wordmark -->
        <a href="/" class="flex items-center gap-3 no-underline" aria-label="Starbloom Consulting LLC Home">
          <img src="/images/starbloom-logo.jpg" alt="Starbloom Consulting" class="h-8 w-auto" />
        </a>

        <!-- Nav Links (Desktop) -->
        <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-text-muted">
          <li>
            <a href="/" class="hover:text-white-pure transition-colors duration-200">Platform</a>
          </li>
          <li>
            <a href="/about" class="hover:text-white-pure transition-colors duration-200">About</a>
          </li>
          <li>
            <a href="/case-studies" class="hover:text-white-pure transition-colors duration-200">Case Studies</a>
          </li>
          <li>
            <a href="/blog" class="hover:text-white-pure transition-colors duration-200">Blog</a>
          </li>
          <li>
            <a href="/pricing" class="hover:text-white-pure transition-colors duration-200">Pricing</a>
          </li>
          <li>
            <a href="/apex-signal-agency" class="hover:text-white-pure transition-colors duration-200">Apex Signal</a>
          </li>
          <li>
            <a
              href="https://buy.stripe.com/3cI6oH0664uAcrIgxI4ow02"
              target="_blank"
              class="px-4 py-2 rounded-lg bg-accent text-white-pure font-semibold hover:bg-blue-600 transition-colors duration-200"
            >
Subscribe — $797/mo
            </a>
          </li>
        </ul>

        <!-- Mobile Hamburger (placeholder — Phase 2) -->
        <button
          class="md:hidden text-text-muted hover:text-white-pure transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      </nav>
    </header>

    <!-- ═══ MAIN: Page Content ═══ -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- ═══ FOOTER: Company Info + Legal + Semantic Links ═══ -->
    <footer class="border-t border-slate-700/50 bg-slate-900 mt-auto" role="contentinfo">
      <div class="container-site py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Column 1: Brand -->
        <div>
          <img src="/images/starbloom-logo.jpg" alt="Starbloom Consulting" class="h-10 w-auto mb-2" />
          <p class="mt-2 text-sm text-text-muted max-w-xs">
            Edge AI & Automation Orchestration Platform. Private infrastructure for operators who build things that matter.
          </p>
        </div>

        <!-- Column 2: Quick Links -->
        <nav aria-label="Footer navigation">
          <h3 class="text-sm font-semibold text-white-pure uppercase tracking-wider mb-3">Platform</h3>
          <ul class="space-y-2 text-sm text-text-muted">
            <li><a href="/#pillars-heading" class="hover:text-white-pure transition-colors">Edge AI Orchestration</a></li>
            <li><a href="/#pillars-heading" class="hover:text-white-pure transition-colors">AI Intake Engine</a></li>
            <li><a href="/#pillars-heading" class="hover:text-white-pure transition-colors">Legacy Data Bridge</a></li>
            <li><a href="/apex-core" class="hover:text-white-pure transition-colors">Apex Core OS</a></li>
            <li><a href="/apex-signal-agency" class="hover:text-white-pure transition-colors">Apex Signal</a></li>
            <li><a href="/pricing" class="hover:text-white-pure transition-colors">Pricing</a></li>
            <li><a href="/about" class="hover:text-white-pure transition-colors">About</a></li>
            <li><a href="/blog" class="hover:text-white-pure transition-colors">Blog</a></li>
            <li><a href="/contact" class="hover:text-white-pure transition-colors">Contact</a></li>
          </ul>
        </nav>

        <!-- Column 3: Contact & Legal -->
        <div>
          <h3 class="text-sm font-semibold text-white-pure uppercase tracking-wider mb-3">Contact</h3>
          <ul class="space-y-2 text-sm text-text-muted">
            <li>
              <span class="text-slate-500 text-xs">Platform Architect</span><br />
              <a href="mailto:darren@starbloomconsulting.com" class="hover:text-white-pure transition-colors">
                darren@starbloomconsulting.com
              </a>
            </li>
            <li>
              <span class="text-slate-500 text-xs">Platform Operations</span><br />
              <a href="mailto:fletcher@starbloomconsulting.com" class="hover:text-white-pure transition-colors">
                fletcher@starbloomconsulting.com
              </a>
            </li>
            <li>
              <a href="https://starbloomconsulting.com" class="hover:text-white-pure transition-colors">
                starbloomconsulting.com
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div class="border-t border-slate-700/30">
        <div class="container-site flex flex-col sm:flex-row items-center justify-between py-4 text-xs text-text-muted">
          <p>&copy; 2025&ndash;2026 Starbloom Consulting LLC. All rights reserved.</p>
          <div class="flex gap-4 mt-2 sm:mt-0">
            <a href="/privacy" class="hover:text-white-pure transition-colors">Privacy Policy</a>
            <a href="/terms" class="hover:text-white-pure transition-colors">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
