  description="Starbloom Consulting LLC Terms of Service. Platform deployment agreements, beta program disclaimers, and limitation of liability for Edge AI & Automation Orchestration services."
  canonicalURL={`${Astro.site}/terms`}
>

  <section class="container-site py-20" aria-labelledby="terms-heading">
    <div class="max-w-3xl mx-auto prose prose-invert prose-slate">
      <h1 id="terms-heading" class="text-4xl font-black text-white-pure tracking-tight">
        Terms of Service
      </h1>
