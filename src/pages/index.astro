---
// Starbloom Consulting LLC V3.0 — Platform Homepage
// Edge-AI & Automation Orchestration Platform
// Three Technical Pillars + Private Beta Gateway

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Edge-AI & Automation Orchestration — Private Beta"
  description="Starbloom Consulting LLC is an Edge-AI & Automation Orchestration Platform. Private AI infrastructure on your hardware. Pre-configured n8n appliances, 24/7 AI voice & SMS intake engines, and legacy data bridge agents. Private Beta — apply for fleet access."
>

  <!-- ==========================================
       HERO — V3.0 Platform Positioning
       H1: Private AI. Your Hardware. Zero Leakage.
       ========================================== -->
  <section class="relative overflow-hidden" aria-labelledby="hero-heading">
    <div class="absolute inset-0 bg-gradient-to-b from-blue-600/5 via-cyan-500/5 to-transparent pointer-events-none" aria-hidden="true"></div>
    <!-- Subtle grid overlay for technical feel -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(59,130,246,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.03)_1px,transparent_1px)] bg-[size:60px_60px] pointer-events-none" aria-hidden="true"></div>

    <div class="container-site py-24 md:py-32 relative z-10">
      <div class="max-w-4xl mx-auto">

        <!-- Eyebrow -->
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent mb-6">
          Edge-AI &amp; Automation Orchestration Platform
        </p>

        <!-- Primary Headline — V3.0 -->
        <h1 id="hero-heading" class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight text-white-pure leading-[1.05]">
          Private AI.<br />
          <span class="text-gradient">Your Hardware.</span><br />
          Zero Leakage.
        </h1>

        <!-- Subhead — Platform framing -->
        <p class="mt-8 text-lg md:text-xl text-text-muted max-w-2xl leading-relaxed">
          Starbloom Consulting LLC is an automated software orchestration platform.
          You bring your own hardware or cloud. We deploy pre-configured Edge-AI appliances,
          24/7 intake engines, and legacy data bridge agents — all running entirely inside
          your infrastructure. No data leaves your walls.
        </p>

        <!-- Private Beta CTA Row -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-accent text-white-pure font-bold text-lg shadow-lg shadow-blue-600/25 hover:bg-blue-600 transition-all duration-200 hover:shadow-blue-500/40"
          >
            Apply for Private Beta Access
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl border border-slate-700 text-text-muted font-semibold hover:text-white-pure hover:border-accent transition-all duration-200"
          >
            Join the Fleet Waitlist
          </a>
        </div>

        <!-- Trust signals row -->
        <div class="mt-12 flex flex-wrap items-center gap-6 text-xs text-text-muted">
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Zero cloud dependency
          </span>
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><polyline points="20 6 9 17 4 12"/></svg>
            Open-source orchestration
          </span>
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Air-gapped by default
          </span>
          <span class="flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-blue-600/15 border border-blue-600/30 text-blue-300 text-xs font-semibold uppercase tracking-wide">
            Restricted Beta Cohort
          </span>
        </div>

      </div>
    </div>
  </section>

  <!-- ==========================================
       THREE TECHNICAL PILLARS — Core Infrastructure
       Semantic 3-column feature grid
       ========================================== -->
  <section class="bg-slate-900/50 border-y border-slate-700/30" aria-labelledby="pillars-heading">
    <div class="container-site py-20">
      <div class="max-w-6xl mx-auto">
        <h2 id="pillars-heading" class="text-3xl md:text-4xl font-black text-white-pure text-center tracking-tight">
          Three <span class="text-gradient">Infrastructure Pillars.</span><br />
          <span class="text-text-muted text-lg font-medium tracking-normal">One orchestration platform.</span>
        </h2>

        <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- ═══ Pillar 1: Edge-AI Orchestration ═══ -->
          <div class="card-surface group hover:glow-border transition-all duration-300 flex flex-col">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-cyan-500/15 mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <span class="text-xs font-bold uppercase tracking-[0.15em] text-cyan-400 mb-2">Pillar 1 — Operations</span>
            <h3 class="text-xl font-bold text-white-pure mb-3">Edge-AI Orchestration</h3>
            <p class="text-sm text-text-muted leading-relaxed flex-1">
              Pre-configured localized hardware appliances running automated n8n workflows 24/7
              via outbound encrypted Cloudflare Tunnels — bypassing client firewall friction completely.
              No incoming ports to open. No VPN configuration. Your workflows run on your hardware
              behind your firewall, orchestrated through a secure outbound-only tunnel.
            </p>
            <ul class="mt-5 space-y-2 text-xs text-text-muted border-t border-slate-700/50 pt-4">
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-400 mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Zero inbound firewall changes required</span>
              </li>
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-400 mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Dockerized n8n + open-source model stack</span>
              </li>
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-400 mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span>24/7 autonomous execution on your schedule</span>
              </li>
            </ul>
          </div>

          <!-- ═══ Pillar 2: 24/7 AI Intake Engine ═══ -->
          <div class="card-surface group hover:glow-border transition-all duration-300 flex flex-col">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-blue-600/15 mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <span class="text-xs font-bold uppercase tracking-[0.15em] text-blue-400 mb-2">Pillar 2 — Revenue Generator</span>
            <h3 class="text-xl font-bold text-white-pure mb-3">24/7 AI Intake Engine</h3>
            <p class="text-sm text-text-muted leading-relaxed flex-1">
              Sub-100ms conversational AI voice and SMS agents integrating Vapi, Retell, and Twilio.
              Instantly answer, qualify, and book emergency home-service jobs directly into client CRMs —
              day or night. No missed calls. No voicemail tag. Revenue capture while your crew sleeps.
            </p>
            <ul class="mt-5 space-y-2 text-xs text-text-muted border-t border-slate-700/50 pt-4">
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-400 mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Sub-100ms response time on voice</span>
              </li>
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-400 mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Qualifies + books directly into job management systems</span>
              </li>
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-400 mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Multi-channel: voice, SMS, web chat</span>
              </li>
            </ul>
          </div>

          <!-- ═══ Pillar 3: Legacy Data Bridge ═══ -->
          <div class="card-surface group hover:glow-border transition-all duration-300 flex flex-col">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-purple-500/15 mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400">
                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
              </svg>
            </div>
            <span class="text-xs font-bold uppercase tracking-[0.15em] text-purple-400 mb-2">Pillar 3 — Data Resilience</span>
            <h3 class="text-xl font-bold text-white-pure mb-3">Legacy Data Bridge</h3>
            <p class="text-sm text-text-muted leading-relaxed flex-1">
              Automated vision-RPA and localized database scraping agents that securely stream data
              out of closed-source, on-premise desktop ERPs directly into Google BigQuery for live
              Looker Studio visualization. No manual CSV exports. No copy-paste. Just continuous,
              automated data liberation from systems that were never designed to talk to anything.
            </p>
            <ul class="mt-5 space-y-2 text-xs text-text-muted border-t border-slate-700/50 pt-4">
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-400 mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Screen-scrape closed-source desktop ERPs</span>
              </li>
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-400 mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Stream to BigQuery → Looker Studio live dashboards</span>
              </li>
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-400 mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Zero API integration required on legacy side</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       PLATFORM TIERS — $500 / $950
       Visual pricing grid preserved for AI crawlers
       Overlaid with "Restricted to Beta Cohort" badges
       No Stripe, no checkout, no Buy Now
       ========================================== -->
  <section class="container-site py-20" aria-labelledby="tiers-heading">
    <div class="max-w-5xl mx-auto">
      <h2 id="tiers-heading" class="text-3xl md:text-4xl font-black text-white-pure text-center tracking-tight">
        Platform <span class="text-gradient">Tiers</span>
      </h2>
      <p class="mt-4 text-center text-text-muted text-sm max-w-xl mx-auto">
        Baseline pricing structures. All tiers currently restricted to the private Beta Cohort.
      </p>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- $500 Tier -->
        <div class="card-surface flex flex-col relative overflow-hidden">
          <!-- Restricted overlay badge -->
          <div class="absolute top-0 right-0 bg-blue-600/90 text-white-pure text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-bl-lg z-10">
            Restricted to Beta Cohort
          </div>
          <h3 class="text-xl font-bold text-white-pure">Foundation Tier</h3>
          <div class="mt-2">
            <span class="text-4xl font-black text-white-pure">$500</span>
            <span class="text-text-muted text-sm"> / deployment</span>
          </div>
          <p class="mt-3 text-sm text-text-muted leading-relaxed">
            Edge-AI Orchestration appliance + single Legacy Data Bridge agent. Pre-configured n8n
            workflows on one local machine. 30 days of follow-on orchestration support.
          </p>
          <ul class="mt-6 space-y-2.5 flex-1 text-sm text-text-muted">
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>1 Edge-AI Orchestration appliance (n8n + open-source models)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>1 Legacy Data Bridge agent (vision-RPA pipeline)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Outbound Cloudflare Tunnel configuration</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>30 days orchestration support</span>
            </li>
          </ul>
          <a
            href="/contact"
            class="mt-8 inline-flex items-center justify-center w-full px-6 py-3 rounded-xl border border-slate-600 text-white-pure font-bold text-sm hover:border-accent hover:text-accent transition-all duration-200"
          >
            Apply for Private Beta Access
          </a>
        </div>

        <!-- $950 Tier -->
        <div class="card-surface flex flex-col glow-border ring-1 ring-blue-600/30 scale-[1.02] relative overflow-hidden">
          <!-- Restricted overlay badge -->
          <div class="absolute top-0 right-0 bg-blue-600/90 text-white-pure text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-bl-lg z-10">
            Restricted to Beta Cohort
          </div>
          <span class="self-start px-3 py-1 mb-4 rounded-full bg-blue-600/20 text-accent text-xs font-bold uppercase tracking-wider">
            Recommended
          </span>
          <h3 class="text-xl font-bold text-white-pure">Fleet Tier</h3>
          <div class="mt-2">
            <span class="text-4xl font-black text-white-pure">$950</span>
            <span class="text-text-muted text-sm"> / deployment</span>
          </div>
          <p class="mt-3 text-sm text-text-muted leading-relaxed">
            Full platform: Edge-AI Orchestration + 24/7 AI Intake Engine + Legacy Data Bridge.
            Multi-channel voice, SMS, and web agents. Two machines. 30 days of premium support.
          </p>
          <ul class="mt-6 space-y-2.5 flex-1 text-sm text-text-muted">
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Everything in Foundation Tier</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>24/7 AI Intake Engine (voice + SMS + web)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>CRM integration (job booking + qualification)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Up to 2 machines + Google BigQuery pipeline</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Live Looker Studio visualization setup</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
              <span>30 days premium orchestration support</span>
            </li>
          </ul>
          <a
            href="/contact"
            class="mt-8 inline-flex items-center justify-center w-full px-6 py-3 rounded-xl bg-accent text-white-pure font-bold text-sm shadow-lg shadow-blue-600/25 hover:bg-blue-600 transition-all duration-200"
          >
            Apply for Private Beta Access
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       DEPLOYMENT — How the platform works
       ========================================== -->
  <section class="bg-slate-900/50 border-y border-slate-700/30" aria-labelledby="how-heading">
    <div class="container-site py-20">
      <h2 id="how-heading" class="text-3xl md:text-4xl font-black text-white-pure text-center tracking-tight">
        Your Platform. Deployed in <span class="text-accent">Days</span>, Not Months.
      </h2>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <!-- Step 1 -->
        <div class="card-surface text-center group hover:glow-border transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-cyan-500/20 text-cyan-400 font-black text-lg mb-4">
            1
          </div>
          <h3 class="text-lg font-bold text-white-pure">Architecture Blueprint</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            60-minute operational deep dive. We map your legacy systems, identify data silos,
            spec the hardware/cloud target, and blueprint the exact orchestration topology
            for your three-pillar deployment.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="card-surface text-center group hover:glow-border transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-600/20 text-accent font-black text-lg mb-4">
            2
          </div>
          <h3 class="text-lg font-bold text-white-pure">Orchestration Deploy</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            We remotely provision your machines with the full orchestration stack — Docker,
            n8n, model runners, Cloudflare Tunnel. Outbound-only encrypted connection.
            Your data never leaves your infrastructure.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="card-surface text-center group hover:glow-border transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-purple-500/20 text-purple-400 font-black text-lg mb-4">
            3
          </div>
          <h3 class="text-lg font-bold text-white-pure">Fleet Handoff &amp; Ops</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            Working AI agents, live dashboards, intake engine online. Team training,
            documentation, and 30 days of premium support. No PhD required to operate
            your fleet.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       FINAL CTA — Private Beta Gateway
       ========================================== -->
  <section class="container-site py-20 text-center" aria-labelledby="final-cta-heading">
    <div class="max-w-2xl mx-auto">
      <div class="inline-block px-4 py-1.5 mb-6 rounded-full bg-blue-600/15 border border-blue-600/30 text-blue-300 text-xs font-bold uppercase tracking-wider">
        Private Beta — Limited Fleet Slots
      </div>
      <h2 id="final-cta-heading" class="text-3xl md:text-4xl font-black text-white-pure tracking-tight">
        Ready to join the <span class="text-gradient">Beta Fleet?</span>
      </h2>
      <p class="mt-4 text-text-muted text-base max-w-xl mx-auto">
        Edge-AI orchestration, 24/7 intake engines, and legacy data bridges —
        all running on your hardware, under your control. Apply now. Fleet slots are limited.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-10 py-5 rounded-xl bg-accent text-white-pure font-bold text-lg shadow-2xl shadow-blue-600/30 hover:bg-blue-600 transition-all duration-200 hover:shadow-blue-500/50 hover:-translate-y-0.5"
        >
          Apply for Private Beta Access
        </a>
        <a
          href="/about"
          class="inline-flex items-center justify-center px-10 py-5 rounded-xl border border-slate-600 text-text-muted font-semibold hover:text-white-pure hover:border-accent transition-all duration-200"
        >
          Learn About the Platform
        </a>
      </div>
      <p class="mt-4 text-xs text-text-muted">
        No checkout. No credit card. Application-only access during Beta.
      </p>
    </div>
  </section>

  <!-- ==========================================
       STRUCTURED DATA: Organization + Service
       Edge-AI & Automation Orchestration Platform
       ========================================== -->
  <script type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
