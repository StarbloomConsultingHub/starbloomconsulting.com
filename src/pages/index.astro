---
// StarBloom Consulting V2 — Homepage
// Phase 2: Full Homepage Engine — Hero, AEO FAQ Repeater, CTA

import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    question: "What exactly is private AI orchestration — and how is it different from ChatGPT or cloud AI?",
    answer: "Private AI orchestration means the AI runs entirely on your hardware, inside your four walls. Unlike ChatGPT, Claude, or any cloud-based AI service, your data never leaves your machines. We deploy and configure open-source models that run locally — no API calls to third parties, no subscription fees, no data leakage. You own the hardware. You own the AI. We just make it work."
  },
  {
    question: "Do I need to buy special hardware from you?",
    answer: "No. This is a BYO-hardware model. You provide the machines — whether that's a single workstation, a repurposed server rack, or a cluster of high-performance rigs. We handle the software: model selection, orchestration layer, agent configuration, and deployment. If you don't have hardware yet, we'll spec it for you, but you buy it directly. We have zero hardware markup."
  },
  {
    question: "What does the $950 starting price include?",
    answer: "The $950 base engagement covers a full architecture consultation, software stack deployment on up to two machines, one private AI agent configured to your use case, and 30 days of follow-on support. It's a complete, working AI system — not a demo, not a proof of concept. More complex multi-agent deployments or larger clusters are scoped and priced transparently after the initial architecture call."
  },
  {
    question: "What kind of businesses is this actually for?",
    answer: "Our customers are operators — people who run real physical operations: farms, nurseries, construction firms, erosion control crews, manufacturing shops, care facilities. These are businesses that generate massive amounts of operational data (schedules, inventory, compliance docs, crew logs, maintenance records) but have no practical way to make AI work on it without shipping it to the cloud. We solve that."
  },
  {
    question: "What models and software do you use?",
    answer: "We work with open-source models that run efficiently on consumer and prosumer hardware — primarily models in the Qwen and Llama families. Our orchestration layer is built on proven open-source tooling (Docker, n8n, Open WebUI). Nothing is proprietary black-box. You can inspect, modify, or extend everything we build. No vendor lock-in, ever."
  },
  {
    question: "Can you guarantee my data stays private?",
    answer: "Yes — structurally. Because the models run locally on your hardware with no outbound API calls, your data cannot leak to a third party even if you wanted it to. There's no network path for it. We configure air-gapped operation by default. The only external connection is for initial software downloads, and even that can be done offline if your security requirements demand it."
  },
  {
    question: "How long does deployment take?",
    answer: "Typical deployment timeline: Architecture call (1 hour) → hardware prep and software provisioning (3–5 business days) → agent configuration and handoff (1–2 business days). You'll have a working private AI system within a week of the architecture call, assuming your hardware is ready."
  },
  {
    question: "What ongoing support do you provide?",
    answer: "Every engagement includes 30 days of follow-on support: model updates, agent tuning, and troubleshooting. After that, we offer a flat-rate retainer for ongoing orchestration management and expansion. No per-seat licensing, no usage-based billing, no surprises."
  }
];
---

<Layout
  title="Private AI on Your Hardware — Starting at $950"
  description="StarBloom Consulting deploys private AI clusters on your hardware. Software deployment and agent orchestration. BYO hardware. Starting at $950. No cloud, no data leakage, no subscriptions."
>

  <!-- ==========================================
       HERO SECTION
       Clear positioning: Software-only, BYO hardware, $950
       ========================================== -->
  <section class="relative overflow-hidden" aria-labelledby="hero-heading">
    <!-- Subtle background glow -->
    <div class="absolute inset-0 bg-gradient-to-b from-blue-600/5 via-transparent to-transparent pointer-events-none" aria-hidden="true"></div>

    <div class="container-site py-24 md:py-32 relative z-10">
      <div class="max-w-4xl mx-auto">

        <!-- Eyebrow -->
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent mb-6">
          Software Deployment &amp; Agent Orchestration
        </p>

        <!-- Primary Headline -->
        <h1 id="hero-heading" class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight text-white-pure leading-[1.05]">
          Private AI.<br />
          <span class="text-gradient">Your Hardware.</span><br />
          Zero Leakage.
        </h1>

        <!-- Subhead -->
        <p class="mt-8 text-lg md:text-xl text-text-muted max-w-2xl leading-relaxed">
          We deploy open-source AI models and autonomous agents on machines you already own.
          No cloud APIs. No data leaving your building. No monthly subscriptions.
          One flat engagement starting at <strong class="text-white-pure font-semibold">$950</strong>.
        </p>

        <!-- CTA Row -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-accent text-white-pure font-bold text-lg shadow-lg shadow-blue-600/25 hover:bg-blue-600 transition-all duration-200 hover:shadow-blue-500/40"
          >
            Book a Discovery Call
          </a>
          <a
            href="#faq"
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl border border-slate-700 text-text-muted font-semibold hover:text-white-pure hover:border-slate-500 transition-all duration-200"
          >
            How It Works
          </a>
        </div>

        <!-- Trust signals (subtle) -->
        <div class="mt-12 flex flex-wrap items-center gap-6 text-xs text-text-muted">
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Zero cloud dependency
          </span>
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><polyline points="20 6 9 17 4 12"/></svg>
            Open-source stack
          </span>
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Air-gapped by default
          </span>
        </div>

      </div>
    </div>
  </section>

  <!-- ==========================================
       HOW IT WORKS — 3-STEP PROCESS
       Visual anchor before the FAQ
       ========================================== -->
  <section class="bg-slate-900/50 border-y border-slate-700/30" aria-labelledby="process-heading">
    <div class="container-site py-20">
      <h2 id="process-heading" class="text-3xl md:text-4xl font-black text-white-pure text-center tracking-tight">
        Your AI. Deployed in <span class="text-accent">Days</span>, Not Months.
      </h2>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="card-surface text-center group hover:glow-border transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-600/20 text-accent font-black text-lg mb-4">
            1
          </div>
          <h3 class="text-lg font-bold text-white-pure">Architecture Call</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            60-minute deep dive into your operation. We map your workflows, identify the highest-impact automation targets, and spec the exact model stack for your hardware.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="card-surface text-center group hover:glow-border transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-600/20 text-accent font-black text-lg mb-4">
            2
          </div>
          <h3 class="text-lg font-bold text-white-pure">Deployment &amp; Orchestration</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            We remotely provision your machines with the full software stack — model runners, agent frameworks, workflow automation. Your data stays on your network the entire time.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="card-surface text-center group hover:glow-border transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-600/20 text-accent font-black text-lg mb-4">
            3
          </div>
          <h3 class="text-lg font-bold text-white-pure">Handoff &amp; Training</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            You get working AI agents configured to your use case — plus team training, documentation, and 30 days of support. No AI PhD required to operate it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       AEO FAQ REPEATER
       Semantic <details>/<summary> — machine-readable Q&A
       Also served as JSON-LD FAQPage schema
       ========================================== -->
  <section id="faq" class="container-site py-20" aria-labelledby="faq-heading">
    <div class="max-w-3xl mx-auto">
      <h2 id="faq-heading" class="text-3xl md:text-4xl font-black text-white-pure text-center tracking-tight">
        Private AI, <span class="text-gradient">Answered.</span>
      </h2>
      <p class="mt-4 text-center text-text-muted text-sm max-w-xl mx-auto">
        Real questions from operators evaluating on-premise AI deployment. No jargon. No sales pitch.
      </p>

      <div class="mt-12 space-y-3">
        {faqs.map((faq, i) => (
          <details
            class="card-surface group cursor-pointer hover:border-slate-600 transition-colors duration-200 [&[open]]:glow-border [&[open]]:bg-slate-850/80"
            name="faq-group"
          >
            <summary class="flex items-center justify-between gap-4 font-semibold text-white-pure text-base md:text-lg marker:hidden list-none">
              <span>{faq.question}</span>
              <span class="flex-shrink-0 w-6 h-6 rounded-full border border-slate-600 flex items-center justify-center text-accent text-sm font-bold group-open:hidden transition-transform duration-200">
                +
              </span>
              <span class="flex-shrink-0 w-6 h-6 rounded-full border border-blue-600 bg-blue-600/10 flex items-center justify-center text-blue-300 text-sm font-bold hidden group-open:flex transition-transform duration-200">
                −
              </span>
            </summary>
            <div class="mt-4 pt-4 border-t border-slate-700/50 text-sm text-text-muted leading-relaxed">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>

    <!-- FAQPage JSON-LD — Structured Data for Answer Engines -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    })}>
    </script>
  </section>

  <!-- ==========================================
       FINAL CTA — Premium, high-contrast
       ========================================== -->
  <section class="bg-slate-900 border-t border-slate-700/30" aria-labelledby="cta-heading">
    <div class="container-site py-20 text-center">
      <h2 id="cta-heading" class="text-3xl md:text-4xl font-black text-white-pure tracking-tight">
        Ready to run AI on <span class="text-gradient">your terms?</span>
      </h2>
      <p class="mt-4 text-text-muted text-base md:text-lg max-w-xl mx-auto">
        One call. One flat price. Private AI that works the way you do — on your hardware, under your control.
      </p>
      <div class="mt-8">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-10 py-5 rounded-xl bg-accent text-white-pure font-bold text-lg shadow-2xl shadow-blue-600/30 hover:bg-blue-600 transition-all duration-200 hover:shadow-blue-500/50 hover:-translate-y-0.5"
        >
          Book Your Architecture Call — $950 Flat
        </a>
      </div>
      <p class="mt-4 text-xs text-text-muted">
        No commitments. No upsells. Just a conversation about what private AI can do for your operation.
      </p>
    </div>
  </section>

</Layout>
