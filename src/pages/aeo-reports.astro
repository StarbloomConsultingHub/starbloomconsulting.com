---
// StarBloom Consulting V2 — AEO Reports Landing Page
// Phase 4: Productized B2B Service — A.P.E.X. Site Diagnostic Reports

import Layout from '../layouts/Layout.astro';

const service = {
  name: "A.P.E.X. Site Diagnostic Reports",
  tagline: "Automated technical AEO diagnostics for digital agencies.",
  provider: "StarBloom Consulting",
  priceCurrency: "USD",
  lowPrice: "500.00",
  highPrice: "750.00",
  offerCount: 2,
  deliveryFormat: "PDF + JSON-LD markup payload",
  turnaround: "72 hours"
};

const tiers = [
  {
    name: "A.P.E.X. Core Diagnostic",
    price: "$500",
    priceRaw: "500.00",
    description: "Full technical AEO audit of your client's site — crawl errors, schema gaps, entity coverage, mobile performance, Core Web Vitals, and content structure analysis.",
    includes: [
      "Full site crawl (up to 500 pages) — broken links, redirects, indexing errors",
      "Schema.org audit — missing, malformed, or under-optimized structured data",
      "Entity coverage map — gaps in Organization, Person, Product, FAQ, LocalBusiness schemas",
      "Mobile rendering report — Core Web Vitals snapshot",
      "Content structure analysis — heading hierarchy, semantic HTML5 gaps, answer-engine readiness",
      "Priority-ranked fix list with code-level remediation snippets",
      "Deliverable: 15–25 page PDF report + JSON-LD markup payload"
    ],
    cta: "Order Core Diagnostic — $500"
  },
  {
    name: "A.P.E.X. Full Intelligence Report",
    price: "$750",
    priceRaw: "750.00",
    description: "Everything in the Core Diagnostic plus competitive entity benchmarking, semantic content gap analysis, and a custom structured data markup generation payload ready for deployment.",
    includes: [
      "Everything in A.P.E.X. Core Diagnostic",
      "Competitive entity benchmarking — your client vs. top 3 ranking competitors across all schema types",
      "Semantic content gap analysis — missing entities, thin content pages, keyword-to-entity mapping",
      "Custom JSON-LD markup generation — Organization, FAQ, Article, Product, Service, LocalBusiness as applicable",
      "Implementation-ready payload — copy-paste deployment with inline documentation",
      "Priority-ranked content briefs — 3–5 recommended new pages with target entities and keyword maps",
      "Deliverable: 30–50 page PDF report + deployable JSON-LD markup payload + content briefs"
    ],
    cta: "Order Full Intelligence — $750",
    featured: true
  }
];

const useCases = [
  {
    title: "Agency White-Label",
    body: "Resell A.P.E.X. reports under your own brand. We deliver technical diagnostics; you deliver the strategy and implementation. Add $1,500–$3,000 to every client retainer with a deliverable that proves ROI in the first month."
  },
  {
    title: "New Business Audits",
    body: "Use A.P.E.X. reports as the opening move in your sales process. Walk into a pitch meeting with a 25-page technical diagnostic of the prospect's site — before they've paid you a dollar. Close rates go up when you lead with data."
  },
  {
    title: "Quarterly Health Checks",
    body: "Bundle A.P.E.X. diagnostics into your retainer agreements as quarterly technical health checks. Automated crawl data, schema validation, and entity coverage tracking over time — proving ongoing value to your clients."
  }
];

const faqs = [
  {
    question: "What exactly does an A.P.E.X. report analyze?",
    answer: "A.P.E.X. reports are technical AEO (Answer Engine Optimization) diagnostics. We crawl the target site and audit: structured data (Schema.org JSON-LD), entity coverage across Organization/Person/Product/FAQ schemas, semantic HTML5 structure, Core Web Vitals, mobile rendering, content heading hierarchy, broken links, redirect chains, and indexing errors. The output is a prioritized fix list with code-level remediation snippets."
  },
  {
    question: "Who are these reports for?",
    answer: "A.P.E.X. reports are built for digital agencies and technical SEO consultants who manage multiple client sites. They are white-label-ready — you receive the diagnostic data and structured markup payloads; you handle client delivery and strategy. The reports are technical in nature and assume the recipient understands schema markup, crawl data, and web performance metrics."
  },
  {
    question: "What is the difference between Core ($500) and Full Intelligence ($750)?",
    answer: "Core Diagnostic covers site crawl, schema audit, entity coverage, mobile rendering, and content structure — everything you need to identify and fix technical AEO gaps. Full Intelligence adds competitive entity benchmarking (your client vs. top 3 competitors), semantic content gap analysis, and a custom deployable JSON-LD markup generation payload with content briefs for 3–5 new pages. Full Intelligence is the complete package if you're building a site from scratch or doing a major overhaul."
  },
  {
    question: "What format do the deliverables come in?",
    answer: "Every report includes a PDF document (15–25 pages for Core, 30–50 pages for Full Intelligence) plus a structured data payload. The Full Intelligence tier also includes deployable JSON-LD markup files and content briefs. All files are delivered via secure download link within 72 hours of order."
  },
  {
    question: "Can I white-label these reports for my agency clients?",
    answer: "Yes — A.P.E.X. reports are explicitly designed for agency white-label use. The PDF is cleanly formatted with no StarBloom branding in the body. You present the findings under your own brand, add your strategic recommendations, and bill your client at your own rate. We are the technical engine; you are the face of the deliverable."
  },
  {
    question: "How long does it take to receive a report?",
    answer: "Standard turnaround is 72 hours from order confirmation. Rush delivery (24 hours) is available for an additional $150 — contact us before ordering if you need expedited service. Volume pricing is available for agencies ordering 5+ reports per month."
  },
  {
    question: "What if I need a report for a site larger than 500 pages?",
    answer: "The Core Diagnostic covers up to 500 pages. For larger sites (500–5,000 pages), contact us for custom scoping — pricing scales based on crawl depth and analysis breadth. Enterprise sites (5,000+ pages) typically require a scoping call to identify the highest-priority sections for diagnostic focus."
  }
];
---

<Layout
  title="A.P.E.X. Site Diagnostic Reports — AEO Audits for Agencies"
  description="Automated B2B technical AEO diagnostics for digital agencies. Schema audits, entity coverage maps, competitive benchmarking, and deployable JSON-LD markup payloads. Starting at $500."
  canonicalURL={`${Astro.site}/aeo-reports`}
>

  <!-- ═══════════════════════════════════════════
       HEAD SLOT: Service + Offer Schema Injection
       ═══════════════════════════════════════════ -->
  <slot slot="head" name="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": service.name,
      "description": "Automated B2B technical AEO diagnostics and structural markup payloads for digital agencies. Includes full site crawl, schema.org audit, entity coverage mapping, competitive benchmarking, and deployable JSON-LD markup generation.",
      "provider": {
        "@type": "Organization",
        "name": service.provider,
        "url": Astro.site
      },
      "serviceType": "AEO Diagnostic Reports",
      "areaServed": {
        "@type": "Country",
        "name": "United States"
      },
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": service.priceCurrency,
        "lowPrice": service.lowPrice,
        "highPrice": service.highPrice,
        "offerCount": String(service.offerCount),
        "description": "Two tiers: A.P.E.X. Core Diagnostic ($500) covers crawl, schema audit, entity coverage, mobile rendering, and content structure analysis. A.P.E.X. Full Intelligence Report ($750) adds competitive entity benchmarking, semantic content gap analysis, and deployable JSON-LD markup generation with content briefs.",
        "offers": tiers.map(tier => ({
          "@type": "Offer",
          "name": tier.name,
          "price": tier.priceRaw,
          "priceCurrency": "USD",
          "description": tier.description
        }))
      }
    })}>
    </script>
  </slot>

  <!-- ==========================================
       HERO — Productized service clarity
       ========================================== -->
  <section class="relative overflow-hidden" aria-labelledby="service-heading">
    <div class="absolute inset-0 bg-gradient-to-b from-blue-600/5 via-transparent to-transparent pointer-events-none" aria-hidden="true"></div>
    <div class="container-site py-24 md:py-28 relative z-10">
      <div class="max-w-4xl mx-auto text-center">

        <!-- Eyebrow -->
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent mb-4">
          Productized B2B Service
        </p>

        <!-- Headline -->
        <h1 id="service-heading" class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight text-white-pure leading-[1.05]">
          A.P.E.X.<br />
          <span class="text-gradient">Site Diagnostic Reports</span>
        </h1>

        <!-- Subhead -->
        <p class="mt-6 text-lg text-text-muted max-w-2xl mx-auto leading-relaxed">
          Automated technical AEO diagnostics built for digital agencies.
          Crawl analysis, schema audits, entity coverage maps, and deployable JSON-LD markup payloads —
          white-label-ready. Starting at <strong class="text-white-pure font-semibold">$500</strong> per report.
        </p>

        <!-- Trust signals -->
        <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-xs text-text-muted">
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Delivered in 72 hours
          </span>
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            PDF + JSON-LD payload
          </span>
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            Agency white-label
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       TIER COMPARISON — Core vs Full Intelligence
       ========================================== -->
  <section class="bg-slate-900/50 border-y border-slate-700/30" aria-labelledby="tiers-heading">
    <div class="container-site py-20">
      <div class="max-w-5xl mx-auto">
        <h2 id="tiers-heading" class="text-3xl md:text-4xl font-black text-white-pure text-center tracking-tight">
          Two Tiers. <span class="text-gradient">Zero Fluff.</span>
        </h2>
        <p class="mt-4 text-center text-text-muted text-sm max-w-xl mx-auto">
          Every report is a technical diagnostic, not a sales deck. Choose the depth your client needs.
        </p>

        <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-6">
          {tiers.map(tier => (
            <div class={`card-surface flex flex-col ${tier.featured ? 'glow-border ring-1 ring-blue-600/30 scale-[1.02]' : ''}`}>
              {tier.featured && (
                <span class="self-start px-3 py-1 mb-4 rounded-full bg-blue-600/20 text-accent text-xs font-bold uppercase tracking-wider">
                  Recommended
                </span>
              )}
              <h3 class="text-xl font-bold text-white-pure">{tier.name}</h3>
              <div class="mt-2">
                <span class="text-3xl font-black text-white-pure">{tier.price}</span>
                <span class="text-text-muted text-sm"> / report</span>
              </div>
              <p class="mt-3 text-sm text-text-muted leading-relaxed">{tier.description}</p>

              <div class="mt-6 space-y-2.5 flex-1">
                {tier.includes.map(item => (
                  <div class="flex items-start gap-2 text-sm text-text-muted">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent mt-0.5 flex-shrink-0">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    <span>{item}</span>
                  </div>
                ))}
              </div>

              <a
                href="/contact"
                class={`mt-8 inline-flex items-center justify-center w-full px-6 py-3 rounded-xl font-bold text-sm transition-all duration-200 ${
                  tier.featured
                    ? 'bg-accent text-white-pure shadow-lg shadow-blue-600/25 hover:bg-blue-600'
                    : 'border border-slate-600 text-white-pure hover:border-accent hover:text-accent'
                }`}
              >
                {tier.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       USE CASES — Agency value props
       ========================================== -->
  <section class="container-site py-20" aria-labelledby="usecases-heading">
    <div class="max-w-4xl mx-auto">
      <h2 id="usecases-heading" class="text-3xl font-black text-white-pure text-center tracking-tight">
        Built for <span class="text-gradient">Agency Workflows</span>
      </h2>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        {useCases.map(uc => (
          <div class="card-surface hover:glow-border transition-all duration-300">
            <h3 class="text-lg font-bold text-white-pure">{uc.title}</h3>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">{uc.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==========================================
       FAQ — Product-specific questions
       ========================================== -->
  <section class="bg-slate-900/50 border-y border-slate-700/30" aria-labelledby="reports-faq-heading">
    <div class="container-site py-20">
      <div class="max-w-3xl mx-auto">
        <h2 id="reports-faq-heading" class="text-3xl font-black text-white-pure text-center tracking-tight">
          A.P.E.X. Reports, <span class="text-gradient">Explained.</span>
        </h2>

        <div class="mt-12 space-y-3">
          {faqs.map((faq, i) => (
            <details
              class="card-surface group cursor-pointer hover:border-slate-600 transition-colors duration-200 [&[open]]:glow-border [&[open]]:bg-slate-850/80"
              name="apex-faq-group"
            >
              <summary class="flex items-center justify-between gap-4 font-semibold text-white-pure text-base marker:hidden list-none">
                <span>{faq.question}</span>
                <span class="flex-shrink-0 w-6 h-6 rounded-full border border-slate-600 flex items-center justify-center text-accent text-sm font-bold group-open:hidden transition-transform duration-200">
                  +
                </span>
                <span class="flex-shrink-0 w-6 h-6 rounded-full border border-blue-600 bg-blue-600/10 flex items-center justify-center text-blue-300 text-sm font-bold hidden group-open:flex transition-transform duration-200">
                  −
                </span>
              </summary>
              <div class="mt-4 pt-4 border-t border-slate-700/50 text-sm text-text-muted leading-relaxed">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- FAQPage JSON-LD for this page's FAQ -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(faq => ({
          "@type": "Question",
          "name": faq.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer
          }
        }))
      })}>
      </script>
    </div>
  </section>

  <!-- ==========================================
       FINAL CTA
       ========================================== -->
  <section class="container-site py-20 text-center" aria-labelledby="apex-cta-heading">
    <h2 id="apex-cta-heading" class="text-3xl md:text-4xl font-black text-white-pure tracking-tight">
      Ready to put <span class="text-gradient">data behind your pitch?</span>
    </h2>
    <p class="mt-4 text-text-muted max-w-lg mx-auto">
      Order an A.P.E.X. report for your next prospect or retainer client.
      White-label delivery in 72 hours. Starting at $500.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-10 py-5 rounded-xl bg-accent text-white-pure font-bold text-lg shadow-2xl shadow-blue-600/30 hover:bg-blue-600 transition-all duration-200 hover:shadow-blue-500/50"
      >
        Order a Report
      </a>
      <a
        href="mailto:fletcher@starbloomconsulting.com"
        class="inline-flex items-center justify-center px-10 py-5 rounded-xl border border-slate-600 text-text-muted font-semibold hover:text-white-pure hover:border-slate-400 transition-all duration-200"
      >
        Inquire About Volume Pricing
      </a>
    </div>
  </section>

</Layout>
