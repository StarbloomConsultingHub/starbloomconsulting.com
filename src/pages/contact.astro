---
// Starbloom Consulting LLC V3.0 — Contact Page
// Fleet Deployment Slot Request — Lead Capture Gateway
// POSTs to n8n webhook → Zoho email onboarding sequence

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Request a Fleet Deployment Slot"
  description="Request a deployment slot for the Starbloom Edge AI &amp; Automation Orchestration Platform. Slots are limited by fleet capacity. Application-only access."
>

  <!-- ==========================================
       PAGE HEADER — Clear conversion framing
       ========================================== -->
  <section class="relative overflow-hidden border-b border-slate-700/30">
    <div class="absolute inset-0 bg-gradient-to-b from-blue-600/5 to-transparent pointer-events-none" aria-hidden="true"></div>
    <div class="container-site py-16 md:py-20 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-block px-4 py-1.5 mb-5 rounded-full bg-blue-600/15 border border-blue-600/30 text-blue-300 text-xs font-bold uppercase tracking-wider">
          Q2/Q3 Deployment Cohort — Application Only
        </div>
        <h1 class="text-3xl md:text-5xl font-black text-white-pure tracking-tight leading-tight">
          Request a <span class="text-gradient">Fleet Deployment</span> Slot
        </h1>
        <p class="mt-4 text-text-muted text-base md:text-lg max-w-xl mx-auto leading-relaxed">
          Deployment slots are limited by fleet capacity. Each client receives
          dedicated Edge AI orchestration on their own hardware — we scale by design, not by overcommitting.
        </p>
      </div>
    </div>
  </section>

  <!-- ==========================================
       FORM SECTION — High-converting Beta Application
       ========================================== -->
  <section class="container-site py-12 md:py-16" aria-labelledby="form-heading">
    <div class="max-w-2xl mx-auto">

      <div class="card-surface glow-border">
        <h2 id="form-heading" class="text-xl font-bold text-white-pure mb-1">
          Fleet Deployment Application
        </h2>
        <p class="text-sm text-text-muted mb-8">
          All fields required. We review applications within 2 business days.
        </p>

        <!-- ═══ FORM ═══ -->
        <form
          id="fleet-deployment-request"
          name="fleet-deployment-request"
          method="POST"
          action="https://waters-explained-obtaining-sets.trycloudflare.com/webhook/beta-application"
          class="space-y-6"
          novalidate
        >

          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-white-pure mb-2">
              Full Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              placeholder="Darren Williams"
              class="w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-white-soft placeholder:text-slate-600 focus:outline-none focus:border-accent focus:ring-2 focus:ring-blue-600/20 transition-all duration-200 text-sm"
            />
          </div>

          <!-- Company Email -->
          <div>
            <label for="email" class="block text-sm font-semibold text-white-pure mb-2">
              Company Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              placeholder="you@yourcompany.com"
              class="w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-white-soft placeholder:text-slate-600 focus:outline-none focus:border-accent focus:ring-2 focus:ring-blue-600/20 transition-all duration-200 text-sm"
            />
            <p class="mt-1 text-xs text-slate-600">No personal addresses (Gmail, Yahoo, etc.) — company domain required.</p>
          </div>

          <!-- Legacy Systems -->
          <div>
            <label for="legacy-systems" class="block text-sm font-semibold text-white-pure mb-2">
              Legacy Systems Currently in Use
            </label>
            <textarea
              id="legacy-systems"
              name="legacy_systems"
              required
              rows="3"
              placeholder="e.g., QuickBooks Desktop 2023, ServiceTitan, Excel-based scheduling, custom ERP on Windows Server, paper dispatch logs..."
              class="w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-white-soft placeholder:text-slate-600 focus:outline-none focus:border-accent focus:ring-2 focus:ring-blue-600/20 transition-all duration-200 text-sm resize-y"
            ></textarea>
            <p class="mt-1 text-xs text-slate-600">What software, spreadsheets, or manual systems does your operation run on today? Be specific — it helps us blueprint faster.</p>
          </div>

          <!-- Primary Automation Goal -->
          <div>
            <label for="automation-goal" class="block text-sm font-semibold text-white-pure mb-2">
              Primary Automation Goal
            </label>
            <textarea
              id="automation-goal"
              name="automation_goal"
              required
              rows="3"
              placeholder="e.g., Automate after-hours emergency call booking, pull job data out of legacy desktop ERP into live dashboards, reduce crew scheduling admin by 80%, capture missed revenue from unanswered calls..."
              class="w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-white-soft placeholder:text-slate-600 focus:outline-none focus:border-accent focus:ring-2 focus:ring-blue-600/20 transition-all duration-200 text-sm resize-y"
            ></textarea>
            <p class="mt-1 text-xs text-slate-600">What's the #1 bottleneck or revenue leak you want automation to solve?</p>
          </div>

          <!-- Tier Preference (hidden but useful for routing) -->
          <input type="hidden" name="source" value="starbloomconsulting.com" />
          <input type="hidden" name="form_id" value="v3-fleet-deployment-request" />

          <!-- Submit -->
          <div class="pt-2">
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center px-8 py-4 rounded-xl bg-accent text-white-pure font-bold text-base shadow-lg shadow-blue-600/25 hover:bg-blue-600 transition-all duration-200 hover:shadow-blue-500/40 hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0"
            >
              Request Fleet Deployment Slot
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </button>
          </div>

          <!-- Trust line -->
          <p class="text-xs text-center text-slate-600">
            No credit card. No commitment. Your information stays inside Starbloom Consulting LLC systems.
            We'll never share or sell your data.
          </p>
        </form>

        <!-- ═══ Success State (hidden by default, shown via JS) ═══ -->
        <div
          id="form-success"
          class="hidden text-center py-8"
          role="alert"
        >
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-500/15 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white-pure mb-2">Application Received</h3>
          <p class="text-text-muted text-sm leading-relaxed max-w-md mx-auto">
            Your application has been received. We review each deployment request
            against current fleet capacity and respond within <strong class="text-white-soft">2 business days</strong>.
            Check your inbox for confirmation.
          </p>
        </div>

        <!-- ═══ Error State (hidden by default, shown via JS) ═══ -->
        <div
          id="form-error"
          class="hidden text-center py-8"
          role="alert"
        >
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-500/15 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400">
              <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white-pure mb-2">Something Went Wrong</h3>
          <p class="text-text-muted text-sm leading-relaxed max-w-md mx-auto mb-4">
            The form couldn't be submitted. Please try again or email us directly at
            <a href="mailto:fletcher@starbloomconsulting.com" class="text-accent hover:underline">fletcher@starbloomconsulting.com</a>.
          </p>
          <button
            id="form-retry"
            type="button"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl border border-slate-600 text-white-pure font-semibold text-sm hover:border-accent transition-all duration-200"
          >
            Try Again
          </button>
        </div>
      </div>

      <!-- ==========================================
           WHAT HAPPENS NEXT — Expectation setting
           ========================================== -->
      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-5 max-w-2xl mx-auto">
        <div class="card-surface text-center">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-blue-600/15 text-accent font-bold text-sm mb-3">
            1
          </div>
          <h3 class="text-sm font-semibold text-white-pure mb-1">We Review</h3>
          <p class="text-xs text-text-muted">
            Your application lands in our intake pipeline. We evaluate your legacy stack and automation goals.
          </p>
        </div>
        <div class="card-surface text-center">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-blue-600/15 text-accent font-bold text-sm mb-3">
            2
          </div>
          <h3 class="text-sm font-semibold text-white-pure mb-1">We Blueprint</h3>
          <p class="text-xs text-text-muted">
            If your operation is a fit, we schedule a 60-minute architecture session to map your three-pillar deployment.
          </p>
        </div>
        <div class="card-surface text-center">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-blue-600/15 text-accent font-bold text-sm mb-3">
            3
          </div>
          <h3 class="text-sm font-semibold text-white-pure mb-1">You Deploy</h3>
          <p class="text-xs text-text-muted">
            We provision your hardware, stand up your fleet, and train your team. Days, not months.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ==========================================
       FALLBACK CONTACT — Direct email path
       ========================================== -->
  <section class="border-t border-slate-700/30 bg-slate-900/50">
    <div class="container-site py-10 text-center">
      <p class="text-sm text-text-muted">
        Prefer direct contact? Email us at
        <a href="mailto:fletcher@starbloomconsulting.com" class="text-accent hover:underline font-medium">fletcher@starbloomconsulting.com</a>
        or call your assigned orchestration lead.
      </p>
    </div>
  </section>

</Layout>

<!-- ==========================================
     CLIENT-SIDE FORM HANDLING
     Graceful degradation: if JS is off, the form
     still POSTs directly to n8n via native HTML.
     JS adds success/error UX without breaking that.
     ========================================== -->
<script>
  const form = document.getElementById('fleet-deployment-request') as HTMLFormElement | null;
  const success = document.getElementById('form-success') as HTMLElement | null;
  const error = document.getElementById('form-error') as HTMLElement | null;
  const retryBtn = document.getElementById('form-retry') as HTMLElement | null;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const data = new FormData(form);
      const body = new URLSearchParams(data as any).toString();

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body,
        });

        if (res.ok || res.status === 202) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
          error?.classList.add('hidden');
        } else {
          throw new Error(`Server responded ${res.status}`);
        }
      } catch {
        form.classList.add('hidden');
        error?.classList.remove('hidden');
        success?.classList.add('hidden');
      }
    });
  }

  retryBtn?.addEventListener('click', () => {
    form?.classList.remove('hidden');
    error?.classList.add('hidden');
    success?.classList.add('hidden');
  });
</script>
