---
// Starbloom Consulting LLC V3.0 — About Page
// E-E-A-T Entity Validation, Founder Profile, Platform Origin Story
// AboutPage + ProfilePage Schema updated for Edge AI Platform

import Layout from '../layouts/Layout.astro';

const founder = {
  name: "Darren Kelly",
  givenName: "Darren",
  familyName: "Kelly",
  jobTitle: "Founder & Lead Platform Architect",
  description: "Darren has spent over two decades on the front lines of operations — construction superintending, regional erosion control management, behavior intervention for vulnerable populations, and directing large-scale agricultural facilities with 50-person teams across 21-room rotational production environments. That depth is what he brings to the Edge AI platform: not theoretical knowledge, but the hard-won instinct of someone who has run real crews on real deadlines with real consequences. He translates legacy systems into orchestrated data pipelines, closed-source ERPs into live dashboards, and hardware into automated infrastructure.",
  image: "/images/founder.jpg",
  sameAs: [
    "https://www.linkedin.com/in/starbloomconsulting",
    "https://starbloomconsulting.com/about",
    "https://fingerboardfarm.market/pages/meet-the-2025-homegrowers-cup-judges",
    "https://cannabiscupwinners.com/blog/2024/11/19/maryland-home-growers-cup-2024/",
    "https://leafmagazines.com/profiles/grows-gardens/maryland-leaf-harvest-special-kind-therapeutics-usa/"
  ],
  knowsAbout: [
    "Edge AI Orchestration Architecture",
    "N8N Workflow Automation",
    "Cloudflare Zero Trust Tunnels",
    "Conversational AI Voice Agent Deployment",
    "Vision-RPA Legacy Data Extraction",
    "Google BigQuery Pipeline Engineering",
    "Looker Studio Dashboard Design",
    "On-Premise LLM Deployment",
    "Docker Container Orchestration",
    "CRM & Job Management Integration"
  ]
};

const organization = {
  name: "Starbloom Consulting LLC",
  legalName: "Starbloom Consulting LLC",
  foundingDate: "2025",
  description: "Starbloom Consulting LLC is an Edge AI & Automation Orchestration Platform for blue-collar, home-service, and operational industries. We deploy pre-configured hardware appliances running automated n8n workflows via outbound encrypted Cloudflare Tunnels, 24/7 conversational AI intake engines, and legacy data bridge agents that liberate data from closed-source desktop ERPs into live cloud visualization — all running on client-owned hardware with zero data leakage.",
  foundingLocation: "Maryland, USA",
  areaServed: "United States",
  knowsAbout: [
    "Edge AI Infrastructure",
    "N8N Workflow Orchestration",
    "AI Voice & SMS Intake Systems",
    "Vision-RPA Data Extraction",
    "Google BigQuery & Looker Studio",
    "On-Premise Model Deployment",
    "Cloudflare Tunnel Networking"
  ]
};

const credentials = [
  {
    category: "Operations Command",
    items: [
      "20+ years managing labor crews, construction sites, and production facilities",
      "Directed 50-person teams across 21-room rotational production environments",
      "Designed and implemented full SOP libraries from scratch — zero-downtime scheduling"
    ]
  },
  {
    category: "Platform Engineering",
    items: [
      "Architected multi-node Edge AI orchestration clusters on consumer and prosumer hardware",
      "Deployed air-gapped LLM environments with zero outbound API dependencies",
      "Engineered outbound-only Cloudflare Tunnel topologies that bypass enterprise firewall friction",
      "Integrated Docker, n8n, Ollama, and Open WebUI into cohesive private stacks"
    ]
  },
  {
    category: "Automation & Data Liberation",
    items: [
      "Built vision-RPA agents that extract data from closed-source legacy desktop ERPs",
      "Engineered real-time BigQuery streaming pipelines from on-premise systems",
      "Developed autonomous AI agent frameworks handling thousands of operational signals daily",
      "Created 24/7 conversational AI intake agents integrating Vapi, Retell, and Twilio"
    ]
  }
];

const values = [
  {
    title: "No Cloud, No Compromise",
    body: "We do not route your operational data through third-party servers. Every model, every agent, every pipeline runs on hardware you control. Outbound-only encrypted tunnels. Zero inbound firewall changes. If it can't run locally, we don't deploy it."
  },
  {
    title: "Open-Source Orchestration",
    body: "Our stack is inspectable and extensible: Docker, n8n, Ollama, open-source LLMs, Cloudflare Tunnel. No proprietary black boxes. You own the configs, the workflows, and the models. We provide documentation, not vendor lock-in."
  },
  {
    title: "Operator-First Design",
    body: "We don't build dashboards for data scientists. We build platforms for foremen, crew leads, farm managers, and small business owners — people who need AI-powered automation to work without requiring a PhD to operate it."
  },
  {
    title: "Transparent Fleet Pricing",
    body: "Foundation Tier at $500 one-time + $499/month support. Fleet Tier at $950 one-time + $599/month premium support. Flat, upfront, transparent. No per-seat licensing, no usage-based billing, no surprise invoices. Currently restricted to the Private Beta Cohort."
  }
];
---

<Layout
  title="About Starbloom — The Edge AI Orchestration Platform"
  description="Starbloom Consulting LLC is an Edge AI & Automation Orchestration Platform. Founded by operators. Deploying private AI infrastructure on client-owned hardware. Three pillars: Edge AI Orchestration, 24/7 AI Intake Engine, Legacy Data Bridge."
  canonicalURL={`${Astro.site}/about`}
  ogImage="/images/founder.jpg"
>

  <!-- ==========================================
       PAGE HEADER — Platform Origin
       ========================================== -->
  <section class="relative overflow-hidden border-b border-slate-700/30" aria-labelledby="about-heading">
    <div class="absolute inset-0 bg-gradient-to-b from-blue-600/5 via-cyan-500/5 to-transparent pointer-events-none" aria-hidden="true"></div>
    <div class="container-site py-20 relative z-10 text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent mb-4">About the Platform</p>
      <h1 id="about-heading" class="text-4xl md:text-5xl font-black tracking-tight text-white-pure">
        Built by <span class="text-gradient">Operators</span>,<br class="sm:hidden" /> for Operators.
      </h1>
      <p class="mt-6 text-text-muted text-base md:text-lg max-w-2xl mx-auto leading-relaxed">
        We are not a VC-backed SaaS startup. We are an Edge AI &amp; Automation Orchestration
        Platform built by someone who has run real crews on real deadlines with real consequences.
        Three infrastructure pillars. One platform. Your hardware. Zero leakage.
      </p>
    </div>
  </section>

  <!-- ==========================================
       THE PROBLEM WE SOLVE
       ========================================== -->
  <section class="container-site py-20" aria-labelledby="story-heading">
    <div class="max-w-4xl mx-auto">
      <h2 id="story-heading" class="text-3xl font-black text-white-pure tracking-tight">
        The Platform Thesis
      </h2>
      <div class="mt-8 space-y-5 text-text-muted leading-relaxed">
        <p>
          Every operating business generates a firehose of data: schedules, inventory, compliance
          documents, maintenance records, crew logs, incoming calls, job bookings. Most of it lives
          trapped inside closed-source legacy systems — desktop ERPs built in 2003, job management
          tools with no API, voicemail boxes that fill up overnight.
        </p>
        <p>
          The mainstream AI industry has one answer: upload your data to our cloud. Ship it to our
          API. Trust our infrastructure. Pay per token, per seat, per month — forever.
        </p>
        <p class="text-white-pure font-medium">
          We rejected that answer on three fronts.
        </p>
        <p>
          <strong class="text-cyan-400">Pillar One — Edge AI Orchestration:</strong> Pre-configured
          local appliances running automated n8n workflows 24/7 via outbound Cloudflare Tunnels.
          Your hardware, your firewall, your rules. Zero inbound ports.
        </p>
        <p>
          <strong class="text-blue-400">Pillar Two — 24/7 AI Intake Engine:</strong> Sub-100ms
          conversational AI voice and SMS agents that answer, qualify, and book jobs while your crew
          sleeps. Integrated directly into your CRM. No missed calls. No voicemail tag.
        </p>
        <p>
          <strong class="text-purple-400">Pillar Three — Legacy Data Bridge:</strong> Vision-RPA
          agents that scrape data out of closed-source desktop ERPs and stream it into Google
          BigQuery for live Looker Studio dashboards. No manual CSV exports. Just continuous,
          automated data liberation.
        </p>
        <p>
          Starbloom Consulting LLC is the orchestration layer that connects all three.
          Three pillars. One platform. Your infrastructure.
        </p>
      </div>
    </div>
  </section>

  <!-- ==========================================
       FOUNDER PROFILE
       ========================================== -->
  <section class="bg-slate-900 border-y border-slate-700/30" aria-labelledby="founder-heading">
    <div class="container-site py-20">
      <div class="max-w-4xl mx-auto">
        <h2 id="founder-heading" class="text-3xl font-black text-white-pure tracking-tight text-center">
          Meet the Platform Architect
        </h2>

        <div class="mt-12 flex flex-col md:flex-row gap-10 items-start">
          <div class="flex-shrink-0 mx-auto md:mx-0">
            <div class="w-32 h-32 rounded-2xl bg-slate-800 border border-slate-700 overflow-hidden shadow-lg shadow-black/30">
              <img
                src="/images/founder.jpg"
                alt="Darren — Founder & Lead Platform Architect at Starbloom Consulting LLC"
                width="128"
                height="128"
                class="w-full h-full object-cover"
                loading="eager"
                decoding="sync"
                itemprop="image"
              />
            </div>
            <p class="mt-3 text-center text-sm text-text-muted">
              {founder.jobTitle}
            </p>
          </div>

          <div class="flex-1">
            <h3 class="text-2xl font-bold text-white-pure">{founder.name}</h3>
            <p class="mt-1 text-sm text-accent font-semibold">{founder.jobTitle}</p>
            <div class="mt-5 space-y-4 text-text-muted leading-relaxed">
              <p>{founder.description}</p>
            </div>
          </div>
        </div>

        <!-- Competency tags -->
        <div class="mt-10 max-w-4xl mx-auto">
          <h4 class="text-sm font-semibold text-white-pure uppercase tracking-wider mb-3">Platform Competencies</h4>
          <div class="flex flex-wrap gap-2">
            {founder.knowsAbout.map(skill => (
              <span class="px-3 py-1.5 rounded-lg bg-slate-800 border border-slate-700 text-xs text-text-muted font-medium">
                {skill}
              </span>
            ))}
          </div>

          <!-- LinkedIn Profile Badge — Verified Trust Signal -->
          <div class="mt-6 flex justify-center">
            <div
              class="badge-base LI-profile-badge"
              data-locale="en_US"
              data-size="medium"
              data-theme="dark"
              data-type="VERTICAL"
              data-vanity="starbloomconsulting"
              data-version="v1"
            >
              <a
                class="badge-base__link LI-simple-link"
                href="https://www.linkedin.com/in/starbloomconsulting"
                rel="me"
              >
                Darren Kelly on LinkedIn
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       INDUSTRY RECOGNITION — External Citations
       Verifiable third-party expertise signals (E-E-A-T)
       ========================================== -->
  <section class="container-site py-16" aria-labelledby="recognition-heading">
    <div class="max-w-4xl mx-auto">
      <h2 id="recognition-heading" class="text-3xl font-black text-white-pure tracking-tight text-center">
        Industry Recognition
      </h2>
      <p class="mt-4 text-center text-text-muted text-sm max-w-xl mx-auto">
        Independent, verifiable citations from third-party industry publications and events.
      </p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- 2024 Cup Win -->
        <a
          href="https://cannabiscupwinners.com/blog/2024/11/19/maryland-home-growers-cup-2024/"
          target="_blank"
          rel="noopener noreferrer"
          class="card-surface hover:glow-border transition-all duration-300 group no-underline"
        >
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
              <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
              <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
              <path d="M4 22h16"/>
              <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
              <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
              <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
            </svg>
            <span class="text-xs font-semibold uppercase tracking-wider text-cyan-400">2024 Champion</span>
          </div>
          <h3 class="text-base font-bold text-white-pure group-hover:text-accent transition-colors">
            Maryland Home Growers Cup
          </h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            1st Place — Judges' Choice. "Trop Cherry" cultivar. CannabisCupWinners.com.
          </p>
          <span class="inline-block mt-3 text-xs text-accent font-medium group-hover:underline">
            View Citation →
          </span>
        </a>

        <!-- 2025 Judge Panel -->
        <a
          href="https://fingerboardfarm.market/pages/meet-the-2025-homegrowers-cup-judges"
          target="_blank"
          rel="noopener noreferrer"
          class="card-surface hover:glow-border transition-all duration-300 group no-underline"
        >
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
              <path d="M12 20h9"/>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
            <span class="text-xs font-semibold uppercase tracking-wider text-purple-400">2025 Judge</span>
          </div>
          <h3 class="text-base font-bold text-white-pure group-hover:text-accent transition-colors">
            Fingerboard Farm Homegrowers Cup
          </h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            Invited back as a competition judge after winning the previous two years. Published panel bio names Starbloom Consulting.
          </p>
          <span class="inline-block mt-3 text-xs text-accent font-medium group-hover:underline">
            View Judge Bio →
          </span>
        </a>

        <!-- Leaf Magazine Feature -->
        <a
          href="https://leafmagazines.com/profiles/grows-gardens/maryland-leaf-harvest-special-kind-therapeutics-usa/"
          target="_blank"
          rel="noopener noreferrer"
          class="card-surface hover:glow-border transition-all duration-300 group no-underline"
        >
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
            <span class="text-xs font-semibold uppercase tracking-wider text-blue-400">Print Feature</span>
          </div>
          <h3 class="text-base font-bold text-white-pure group-hover:text-accent transition-colors">
            Maryland Leaf Magazine
          </h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            Full facility profile — November 2025 Harvest Special. Covers 21-room operation, career trajectory, and Starbloom Consulting.
          </p>
          <span class="inline-block mt-3 text-xs text-accent font-medium group-hover:underline">
            Read Article →
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ==========================================
       CREDENTIALS — Three columns
       ========================================== -->
  <section class="container-site py-20" aria-labelledby="credentials-heading">
    <div class="max-w-4xl mx-auto">
      <h2 id="credentials-heading" class="text-3xl font-black text-white-pure tracking-tight text-center">
        Platform Credentials
      </h2>
      <p class="mt-4 text-center text-text-muted text-sm max-w-xl mx-auto">
        Hands-on experience from the trades, not a conference badge.
      </p>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
        {credentials.map(col => (
          <div class="card-surface">
            <h3 class="text-base font-bold text-white-pure mb-3">{col.category}</h3>
            <ul class="space-y-2.5">
              {col.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-text-muted leading-relaxed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent mt-0.5 flex-shrink-0">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==========================================
       PLATFORM TIERS — $500 / $950
       Preserved for crawlers with cohort overlay
       ========================================== -->
  <section class="bg-slate-900/50 border-y border-slate-700/30" aria-labelledby="about-tiers-heading">
    <div class="container-site py-20">
      <div class="max-w-5xl mx-auto">
        <h2 id="about-tiers-heading" class="text-3xl font-black text-white-pure text-center tracking-tight">
          Platform <span class="text-gradient">Tiers</span>
        </h2>
        <p class="mt-4 text-center text-text-muted text-sm max-w-xl mx-auto">
          Baseline deployment pricing. All tiers currently in the Q2/Q3 deployment cohort.
        </p>

        <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- $500 -->
          <div class="card-surface flex flex-col relative overflow-hidden">
            <div class="absolute top-0 right-0 bg-blue-600/90 text-white-pure text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-bl-lg z-10">
              Q2/Q3 Cohort
            </div>
            <h3 class="text-xl font-bold text-white-pure">Foundation Tier</h3>
            <div class="mt-2">
              <span class="text-4xl font-black text-white-pure">$500</span>
              <span class="text-text-muted text-sm"> one-time</span>
            </div>
            <p class="mt-1 text-sm text-text-muted">
              <span class="font-semibold text-white-pure">$499/month</span> ongoing support
            </p>
            <p class="mt-3 text-sm text-text-muted leading-relaxed">
              Edge AI Orchestration + Legacy Data Bridge. One machine. 30 days onboarding support.
            </p>
          </div>

          <!-- $950 -->
          <div class="card-surface flex flex-col relative overflow-hidden glow-border ring-1 ring-blue-600/30 scale-[1.02]">
            <div class="absolute top-0 right-0 bg-blue-600/90 text-white-pure text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-bl-lg z-10">
              Q2/Q3 Cohort
            </div>
            <span class="self-start px-3 py-1 mb-4 rounded-full bg-blue-600/20 text-accent text-xs font-bold uppercase tracking-wider">
              Recommended
            </span>
            <h3 class="text-xl font-bold text-white-pure">Fleet Tier</h3>
            <div class="mt-2">
              <span class="text-4xl font-black text-white-pure">$950</span>
              <span class="text-text-muted text-sm"> one-time</span>
            </div>
            <p class="mt-1 text-sm text-text-muted">
              <span class="font-semibold text-white-pure">$599/month</span> premium support
            </p>
            <p class="mt-3 text-sm text-text-muted leading-relaxed">
              Full platform: Edge AI Orchestration + 24/7 AI Intake Engine + Legacy Data Bridge.
              Two machines. 30 days onboarding support.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       VALUES
       ========================================== -->
  <section class="container-site py-20" aria-labelledby="values-heading">
    <div class="max-w-4xl mx-auto">
      <h2 id="values-heading" class="text-3xl font-black text-white-pure tracking-tight text-center">
        What We Stand On
      </h2>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
        {values.map(v => (
          <div class="card-surface hover:glow-border transition-all duration-300">
            <h3 class="text-lg font-bold text-white-pure">{v.title}</h3>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==========================================
       CLOSING CTA — Fleet Deployment Gateway
       ========================================== -->
  <section class="bg-slate-900 border-t border-slate-700/30" aria-labelledby="about-cta-heading">
    <div class="container-site py-20 text-center">
      <div class="inline-block px-4 py-1.5 mb-6 rounded-full bg-blue-600/15 border border-blue-600/30 text-blue-300 text-xs font-bold uppercase tracking-wider">
        Q2/Q3 Deployment Cohort — Limited Fleet Slots
      </div>
      <h2 id="about-cta-heading" class="text-3xl font-black text-white-pure tracking-tight">
        Ready to join the <span class="text-gradient">Fleet?</span>
      </h2>
      <p class="mt-4 text-text-muted max-w-lg mx-auto">
        Edge AI orchestration, 24/7 intake engines, and legacy data bridges —
        all running on your hardware. Apply now.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-10 py-5 rounded-xl bg-accent text-white-pure font-bold text-lg shadow-2xl shadow-blue-600/30 hover:bg-blue-600 transition-all duration-200 hover:shadow-blue-500/50"
        >
          Request Fleet Deployment Slot
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-10 py-5 rounded-xl border border-slate-600 text-text-muted font-semibold hover:text-white-pure hover:border-accent transition-all duration-200"
        >
          Join the Fleet Waitlist
        </a>
      </div>
      <p class="mt-4 text-xs text-text-muted">
        No checkout. No credit card. Application-only fleet deployment.
      </p>
    </div>
  </section>

  <!-- ==========================================
       STRUCTURED DATA: AboutPage + ProfilePage + Organization
       Updated for Edge AI Platform entity profile
       ========================================== -->
  <script type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "name": "About Starbloom Consulting LLC — Edge AI Platform",
      "url": `${Astro.site}/about`,
      "description": organization.description,
      "about": {
        "@type": "Organization",
        "name": organization.name,
        "legalName": organization.legalName,
        "foundingDate": organization.foundingDate,
        "foundingLocation": organization.foundingLocation,
        "areaServed": organization.areaServed,
        "description": organization.description,
        "logo": `${Astro.site}/og-default.png`,
        "sameAs": [
          Astro.site,
          "https://github.com/StarbloomConsultingHub",
          "https://www.linkedin.com/company/starbloom-consulting-llc"
        ],
        "knowsAbout": [
          { "@type": "Thing", "name": "Edge AI Infrastructure", "sameAs": "http://www.wikidata.org/entity/Q264480" },
          { "@type": "Thing", "name": "n8n Workflow Orchestration", "sameAs": "http://www.wikidata.org/entity/Q106651894" },
          { "@type": "Thing", "name": "Cloudflare Tunnel Networking", "sameAs": "http://www.wikidata.org/entity/Q107116940" },
          { "@type": "Thing", "name": "Docker", "sameAs": "http://www.wikidata.org/entity/Q141206" },
          { "@type": "Thing", "name": "AI Voice & SMS Intake Systems", "sameAs": "http://www.wikidata.org/entity/Q116662155" },
          { "@type": "Thing", "name": "Vision-RPA Data Extraction", "sameAs": "http://www.wikidata.org/entity/Q54803784" },
          { "@type": "Thing", "name": "Google BigQuery & Looker Studio", "sameAs": "http://www.wikidata.org/entity/Q5583808" },
          { "@type": "Thing", "name": "On-Premise Model Deployment", "sameAs": "http://www.wikidata.org/entity/Q7095738" }
        ],
        "url": Astro.site,
        "founder": {
          "@type": "Person",
